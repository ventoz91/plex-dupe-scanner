{
  "ssh": {
    "host": "192.168.1.100",
    "port": 22,
    "username": "your-username"
  },
  "media_paths": [
    "/path/to/plex/media/movies",
    "/path/to/plex/media/tv"
  ],
  "torrent_paths": [
    "/path/to/torrents/movies",
    "/path/to/torrents/tv"
  ],
  "torrent_orphan_move_dest": "/path/to/staging/",
  "output_dir": "./reports",
  "extensions": [
    ".mkv",
    ".mp4",
    ".avi",
    ".mov",
    ".m4v",
    ".wmv"
  ],
  "prefer": {
    "resolution_order": ["2160p", "1080p", "720p", "480p"],
    "codec_order": ["x265", "hevc", "x264", "h264"],
    "prefer_larger_file": true
  },
  "min_size_mb": 0
}
